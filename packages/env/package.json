{
  "name": "@typebot.io/env",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./compiled": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@t3-oss/env-nextjs": "^0.13.10",
    "zod": "^4.3.5"
  },
  "scripts": {
    "compile": "esbuild src/index.ts --bundle --minify --outfile=dist/index.js"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/dist"
        ],
        "defaultConfiguration": "production",
        "options": {
          "command": "bun run compile",
          "cwd": "packages/env"
        },
        "configurations": {
          "development": {
            "command": "bun run compile",
            "cwd": "packages/env"
          },
          "production": {
            "command": "bun run compile",
            "cwd": "packages/env"
          }
        }
      }
    }
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/main.js",
  "main": "./dist/main.js"
}