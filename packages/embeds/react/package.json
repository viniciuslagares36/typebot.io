{
  "name": "@typebot.io/react",
  "version": "0.10.3",
  "description": "Convenient library to display typebots on your React app",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "echo \"Next.js will compile source directly\""
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "outputs": [],
        "defaultConfiguration": "production",
        "options": {
          "command": "echo 'Skipping bundle compilation'"
        }
      }
    }
  },
  "dependencies": {
    "react": "^19.2.4",
    "@typebot.io/js": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}